# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Required: Anthropic API key (used by OpenHands agent + root-cause inference)
ANTHROPIC_API_KEY=sk-ant-...

# Required for PR creation: GitHub personal access token (repo + pull_request scopes)
GITHUB_TOKEN=ghp_...

# Optional: override the default webhook port (default: 5050)
# PORT=5050
